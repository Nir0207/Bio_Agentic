# Core Neo4j connectivity
# For docker-compose in this folder, use the internal service URI.
NEO4J_URI=bolt://neo4j:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=neo4j-password
NEO4J_DATABASE=neo4j
NEO4J_AUTH=neo4j/neo4j-password

# Host port mapping for local access to the compose Neo4j
NEO4J_BOLT_PORT_HOST=7688
NEO4J_HTTP_PORT_HOST=7475

# Retrieval tuning
GRAPH_TOP_K=5
SEMANTIC_TOP_K=5
MAX_GRAPH_HOPS=2
MAX_GRAPH_PATHS=4

# Semantic retrieval strategy: keyword or vector
SEMANTIC_RETRIEVAL_MODE=keyword
VECTOR_INDEX_NAME_PUBLICATION=publication_semantic_embedding_idx
VECTOR_INDEX_NAME_EVIDENCE=evidence_semantic_embedding_idx

# Scoring source: neo4j_property or modeling_artifact
MODEL_SCORE_SOURCE=neo4j_property
MODEL_SCORE_NAME=target_score

# Human-in-the-loop policy
ENABLE_HUMAN_REVIEW=true
HITL_LOW_CONFIDENCE_THRESHOLD=0.45
HITL_MIN_CITATIONS=1
HITL_REQUIRE_REVIEW_ON_CONTRADICTION=true
HITL_REQUIRE_REVIEW_HIGH_STAKES=true
HITL_HIGH_STAKES_TERMS=life-threatening,critical,dose,toxicity,contraindication

# Runtime
LOG_LEVEL=INFO
SAMPLE_QUERY=prioritize EGFR and MAPK pathway evidence in lung cancer
ALLOW_MOCK_FALLBACK_DATA=false
